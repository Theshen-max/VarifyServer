# ==========================================
# Node.js 核心依赖 (绝对不能上传)
# ==========================================
node_modules/
jspm_packages/
.npm/

# ==========================================
# 环境变量与机密文件 (防止密码、Token泄露)
# ==========================================
.env
.env.test
.env.production
.env.local
*.pem
config.json

# ==========================================
# 日志文件
# ==========================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/
*.log

# ==========================================
# 编译与构建输出目录 (如果有使用 TypeScript 或打包工具)
# ==========================================
dist/
build/
out/
.next/
.nuxt/

# ==========================================
# 覆盖率与测试报告
# ==========================================
coverage/
.nyc_output/

# ==========================================
# IDE 缓存与配置文件 (CLion / WebStorm / VSCode)
# ==========================================
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ==========================================
# 操作系统缓存文件
# ==========================================
.DS_Store
Thumbs.db